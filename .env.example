# Briefly service endpoints — copy to `.env` (gitignored) and adjust.
# Loaded automatically by `briefly run` and `briefly watch` (real env vars / CLI flags win).

# --- ASR engine (diarize + transcribe) — see docs/asr-backends.md ---------------------
#   whisperx       : GPU box, transcribe via /asr + diarize via its own /diarize (default; box up)
#   faster-whisper : CPU faster-whisper (timestamps) on the cluster + pyannote diarization
#   wyoming        : legacy wyoming-whisper (text-only, sliced) + pyannote
# Transcribe and diarize stay SEPARATE steps (separate URLs) for every backend.
BRIEFLY_ASR_BACKEND=whisperx
BRIEFLY_WHISPERX_URL=http://192.168.10.70:8000/asr          # the RTX 4080 box — transcribe (/asr)
BRIEFLY_FASTER_WHISPER_URL=http://faster-whisper.example.io/asr
# For the whisperx backend, point BRIEFLY_DIARIZE_URL (below) at the same box's /diarize, e.g.
#   BRIEFLY_DIARIZE_URL=http://192.168.10.70:8000/diarize   # drop-in for the pyannote service

# --- speaker-diarization: internal HTTPRoute (k8s-homelab) ---------------------------
# Resolves on the LAN/gateway. If the gateway cert isn't trusted by the capture laptop,
# port-forward instead:  kubectl -n speaker-diarization port-forward svc/speaker-diarization 8080:80
#   then use  http://localhost:8080/diarize
BRIEFLY_DIARIZE_URL=https://speaker-diarization.example.io/diarize

# --- wyoming-whisper: raw Wyoming over TCP (NO httproute — it's not HTTP) -------------
# Reachable directly on the LAN at 192.168.10.69:10300 (in-cluster:
# wyoming-whisper.wyoming-whisper.svc.cluster.local:10300; or port-forward to localhost).
BRIEFLY_WHISPER_HOST=192.168.10.69
BRIEFLY_WHISPER_PORT=10300

# --- optional ------------------------------------------------------------------------
# BRIEFLY_VAULT_DIR=/path/to/your/Obsidian/Projects
# BRIEFLY_DATA_ROOT=.
# BRIEFLY_SUMMARIZE_MODEL=claude-opus-4-8
# BRIEFLY_CLAUDE_PATH=claude
