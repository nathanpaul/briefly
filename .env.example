# Briefly config — copy to `.env` (gitignored) and adjust. Loaded automatically by `briefly`
# (real env vars and CLI flags override it). The defaults below assume the GPU service from
# deploy/whisperx-gpu/ is running on this machine (an all-local setup).

# --- Diarize + transcribe engine ----------------------------------------------------
#   whisperx       : one GPU box serves /asr (transcribe) and /diarize (default; deploy/whisperx-gpu/)
#   faster-whisper : CPU faster-whisper /asr + a separate pyannote /diarize service
#   wyoming        : legacy wyoming-whisper (text-only) + a separate pyannote /diarize service
ASR_BACKEND=whisperx
TRANSCRIBE_SERVICE_URL=http://localhost:8000/asr     # transcribe + word-align
DIARIZE_URL=http://localhost:8000/diarize            # pyannote diarization (whisperx serves it too)
# Running the GPU box on another machine? Point both at it (e.g. http://192.168.1.50:8000/asr and
# .../diarize) and open that host's port 8000 — see deploy/whisperx-gpu/README.md.

# Alternative backends (uncomment + set ASR_BACKEND above):
# FASTER_WHISPER_URL=http://localhost:8001/asr       # faster-whisper /asr
# WHISPER_HOST=localhost                             # wyoming-whisper (raw Wyoming/TCP)
# WHISPER_PORT=10300

# --- Meetings + data ----------------------------------------------------------------
# MEETING_ID_PREFIX=meeting_                         # meeting ids like meeting_0001 (easy to type later)
# VAULT_DIR=/path/to/your/Obsidian/vault             # where `briefly summarize` writes notes
# DATA_ROOT=.                                        # holds recordings/ processed/ transcripts/

# --- briefly summarize --------------------------------------------------------------
# The instruction Claude follows for `briefly summarize` with no prompt (one page at the vault root).
DEFAULT_SUMMARIZE_PROMPT="Write a concise meeting note: a 2-3 sentence summary, the key decisions, action items with owners, and any open questions."
# Appended to the instruction ONLY when you pass --enrich. Describe your vault's structure and where
# notes go, e.g. "Put blockers in 30-Issues/ as new files; add next steps to 40-NextSteps/."
# ENRICHMENT_PROMPT="..."
# Claude model for summarize (default claude-opus-4-8; claude-sonnet-4-6 / claude-haiku-4-5 are cheaper):
# SUMMARIZE_MODEL=claude-sonnet-4-6
# CLAUDE_PATH=claude                                 # only if `claude` isn't on your PATH

# --- Notifications ------------------------------------------------------------------
# Ping when `process`/`summarize` finish (default off). bell = terminal bell;
# desktop = bell + a macOS notification. Override per run with --notify [desktop].
# NOTIFY=bell
