{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://briefly/schemas/meeting.schema.json",
  "title": "Briefly capture manifest (meeting.json)",
  "type": "object",
  "required": ["schema_version", "meeting_id", "date", "started_at", "partial", "attendees", "capture", "channels"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "meeting_id": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "started_at": {"type": "string"},
    "ended_at": {"type": ["string", "null"]},
    "partial": {"type": "boolean"},
    "attendees": {"type": "array", "items": {"type": "string"}},
    "capture": {
      "type": "object",
      "required": ["mode", "sample_rate", "format", "channels", "ffmpeg", "offset_method"],
      "properties": {
        "mode": {"enum": ["dual-process", "aggregate"]},
        "sample_rate": {"type": "integer"},
        "format": {"type": "string"},
        "channels": {"type": "integer"},
        "ffmpeg": {"type": "string"},
        "offset_method": {"type": "string"}
      }
    },
    "channels": {
      "type": "object",
      "required": ["mic", "line"],
      "properties": {
        "mic": {"$ref": "#/$defs/channel"},
        "line": {"$ref": "#/$defs/channel"}
      }
    }
  },
  "$defs": {
    "channel": {
      "type": "object",
      "required": ["file", "device_name", "start_offset_sec"],
      "properties": {
        "file": {"type": "string"},
        "speaker": {"type": "string"},
        "device_name": {"type": "string"},
        "device_uid": {"type": "string"},
        "start_offset_sec": {"type": "number"},
        "duration_sec": {"type": ["number", "null"]},
        "peak_dbfs": {"type": ["number", "null"]},
        "mean_dbfs": {"type": ["number", "null"]},
        "clipping": {"type": ["boolean", "null"]}
      }
    }
  }
}
