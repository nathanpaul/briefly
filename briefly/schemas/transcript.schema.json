{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://briefly/schemas/transcript.schema.json",
  "title": "Briefly canonical merged transcript (transcript.json)",
  "type": "object",
  "required": ["schema_version", "meeting_id", "date", "partial", "models", "speakers", "turns", "warnings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "meeting_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "generated_at": {"type": ["string", "null"]},
    "partial": {"type": "boolean"},
    "models": {
      "type": "object",
      "properties": {
        "transcription": {"type": ["string", "null"]},
        "diarization": {"type": ["string", "null"]}
      }
    },
    "speakers": {
      "type": "array",
      "items": {"$ref": "#/$defs/speaker"}
    },
    "turns": {
      "type": "array",
      "items": {"$ref": "#/$defs/turn"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "speaker": {
      "type": "object",
      "required": ["id", "label", "name", "channel", "source"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "name": {"type": ["string", "null"]},
        "channel": {"enum": ["mic", "line"]},
        "source": {"enum": ["channel", "diarization"]}
      }
    },
    "turn": {
      "type": "object",
      "required": ["index", "speaker_id", "speaker", "channel", "start", "end", "text", "confidence", "diarization_confidence", "flags"],
      "additionalProperties": false,
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "speaker_id": {"type": "string"},
        "speaker": {"type": "string"},
        "channel": {"enum": ["mic", "line"]},
        "start": {"type": "number"},
        "end": {"type": "number"},
        "text": {"type": "string"},
        "confidence": {"type": ["number", "null"]},
        "diarization_confidence": {"type": ["number", "null"]},
        "flags": {
          "type": "array",
          "items": {"enum": ["overlap", "possible_echo", "unknown_speaker", "low_confidence", "partial"]}
        }
      }
    }
  }
}
