# Copy to .env and fill in. The Hugging Face token is needed ONLY for the diarization
# endpoint (POST /diarize); plain transcribe + word alignment (POST /asr) work without it.
#
# Endpoints (separate steps — point Briefly at each):
#   BRIEFLY_WHISPERX_URL -> http://<host>:8000/asr        transcribe + align (no token needed)
#   BRIEFLY_DIARIZE_URL  -> http://<host>:8000/diarize    diarization (needs HF_TOKEN below);
#                                                         drop-in for the homelab pyannote svc
#
# The diarization model is gated. With pyannote.audio 4.x (whisperX 3.8.6) you can use either
# `community-1` (recommended — matches the homelab pyannote service, so /diarize is a drop-in) or
# `speaker-diarization-3.1`. Accept the terms for whichever you set, plus its internal segmentation:
#   - https://hf.co/pyannote/speaker-diarization-community-1     (recommended)
#   - https://hf.co/pyannote/speaker-diarization-3.1  +  https://hf.co/pyannote/segmentation-3.0
# Then create a READ token at https://hf.co/settings/tokens and paste it below.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The pyannote pipeline /diarize loads (also reported as the response `model`). The app default is
# speaker-diarization-3.1; we set community-1 to match the homelab. (Set in .env so it's overridable.)
WHISPERX_DIARIZE_MODEL=pyannote/speaker-diarization-community-1
